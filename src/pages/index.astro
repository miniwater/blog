---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import {
  CarouselDemo,
  FriendLinkCard,
  StatisticCard,
} from "@/components/index";
import {
  Card,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { config } from "@/config";
import Section from "@/components/Section.astro";

// 获取 blog 集合中的所有文章
const allPosts = await getCollection("blog");
// 获取 docs 集合中的所有文档
const allDocs = await getCollection("docs");

const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6)
  .map((post) => {
    const slug = post.id.split("/").pop();
    return {
      ...post,
      customSlug: slug,
    };
  });

// 文章摘要
function getSummary(body: string, length = 100) {
  const cleanBody = body
    // 1. 过滤图片: ![描述](链接)
    .replace(/!\[.*?\]\(.*?\)/g, "")
    // 2. 过滤常规链接，只保留文本内容: [文本](链接) -> 文本
    .replace(/\[(.*?)\]\(.*?\)/g, "$1")
    // 3. 过滤标题、粗体、斜体、删除线、行内代码
    .replace(/[#*`~]/g, "")
    // 4. 过滤多余的换行符和空格，让摘要更紧凑
    .replace(/\s+/g, " ")
    .trim();
  return cleanBody.slice(0, length) + (cleanBody.length > length ? "..." : "");
}

// 文章总数
const totalPosts = allPosts.length;
// 全站字数
const totalWords =
  allPosts.reduce((acc, post) => {
    return acc + (post.body || "").length;
  }, 0) +
  allDocs.reduce((acc, doc) => {
    return acc + (doc.body || "").length;
  }, 0);
// 最近更新时间
const latestUpdate = (posts[0]||{ data: { date: new Date() } }).data.date.toISOString();
---

<Layout>
  <Section>
    <div class="max-w-2xl mx-auto text-center mb-10 lg:mb-14">
      <h2 class="scroll-m-24 text-3xl font-semibold tracking-tight sm:text-3xl">
        最近文章
      </h2>
      <p
        class="mt-1 text-[1.05rem] text-muted-foreground sm:text-base sm:text-balance"
      >
        用文章的方式记录生活
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 lg:gap-y-10 gap-6">
      {
        posts.map((post) => (
          <Card className="relative mx-auto w-full max-w-sm pt-0 hover:bg-muted">
            <div class="absolute inset-0 z-30 aspect-video" />
            {/* ✅ 正确写法：必须使用 Image 组件 */}
            {post.data.cover ? (
              <Image
                src={post.data.cover}
                alt={post.data.title}
                width={800}
                height={800}
                class="relative z-20 aspect-video w-full object-cover"
              />
            ) : (
              <img
                src="https://avatar.vercel.sh/shadcn1"
                alt="Event cover"
                class="relative z-20 aspect-video w-full object-cover brightness-60 grayscale dark:brightness-40"
              />
            )}
            <CardHeader>
              <CardDescription>
                {post.data.date.toLocaleDateString()}
              </CardDescription>
              <CardTitle>
                <a href={new URL(post.customSlug || "", config.url)}>
                  <span class="absolute inset-0" />
                  {post.data.title}
                </a>
              </CardTitle>
              <CardDescription className="line-clamp-3">
                {getSummary(post.body ?? "")}
              </CardDescription>
            </CardHeader>
          </Card>
        ))
      }
    </div>

    <div class="mt-10 flex justify-center">
      <Button className="" variant="outline">
        <a href={new URL("post", config.url).href}> 更多文章 </a>
      </Button>
    </div>
  </Section>
  <section class="w-full overflow-hidden">
    <div class="max-w-7xl px-4 py-10 lg:py-14 mx-auto">
      <CarouselDemo client:load />
    </div>
  </section>
  <Section>
    <FriendLinkCard client:load />
  </Section>
  <Section>
    <div
      class="grid grid-cols-1 gap-8 mt-8 xl:mt-12 xl:gap-12 md:grid-cols-2 xl:grid-cols-3"
    >
      <div
        class="scroll-animation p-8 space-y-3 border border-gray-200 dark:border-neutral-700 rounded-xl dark:bg-neutral-800"
        style="opacity: 1; transform: translateY(0px);"
      >
        <span class="inline-block text-blue-500 dark:text-blue-400">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"
            ></path>
          </svg>
        </span>

        <h1
          class="text-xl font-semibold text-gray-700 capitalize dark:text-white"
        >
          Markdown
        </h1>

        <p class="text-gray-500 dark:text-gray-300">
          一种轻量级标记语言，它以简洁的语法使人们能够快速地编写格式化文本。
        </p>
      </div>

      <div
        class="scroll-animation p-8 space-y-3 border border-gray-200 dark:border-neutral-700 rounded-xl dark:bg-neutral-800"
        style="opacity: 1; transform: translateY(0px);"
      >
        <span class="inline-block text-blue-500 dark:text-blue-400">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"
            ></path>
          </svg>
        </span>

        <h1
          class="text-xl font-semibold text-gray-700 capitalize dark:text-white"
        >
          Hugo
        </h1>

        <p class="text-gray-500 dark:text-gray-300">
          一个用Go语言编写的静态网站生成器，它能够快速地将Markdown格式的内容转换成静态HTML页面。
        </p>
      </div>

      <div
        class="scroll-animation p-8 space-y-3 border border-gray-200 dark:border-neutral-700 rounded-xl dark:bg-neutral-800"
        style="opacity: 1; transform: translateY(0px);"
      >
        <span class="inline-block text-blue-500 dark:text-blue-400">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-8 h-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
            ></path>
          </svg>
        </span>

        <h1
          class="text-xl font-semibold text-gray-700 capitalize dark:text-white"
        >
          TailwindCSS
        </h1>

        <p class="text-gray-500 dark:text-gray-300">
          一个实用优先的CSS框架，它提供了一套工具类，使开发者可以专注于页面的布局和设计，而无需编写大量自定义CSS代码。
        </p>
      </div>
    </div>
    <StatisticCard client:load totalPosts={totalPosts} totalWords={totalWords} latestUpdate={latestUpdate} />
  </Section>
</Layout>
