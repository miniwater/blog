---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { CarouselDemo, StatisticCard } from "@/components/index";
import {
  Card,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { config, getSummary } from "@/config";
import Section from "@/components/Section.astro";

// 获取 blog 集合中的所有文章
const allPosts = await getCollection("blog");
// 获取 docs 集合中的所有文档
const allDocs = await getCollection("docs");

const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6)
  .map((post) => {
    const slug = post.id.split("/").pop();
    return {
      ...post,
      customSlug: slug,
    };
  });

// 文章总数
const totalPosts = allPosts.length;
// 全站字数
const totalWords =
  allPosts.reduce((acc, post) => {
    return acc + (post.body || "").length;
  }, 0) +
  allDocs.reduce((acc, doc) => {
    return acc + (doc.body || "").length;
  }, 0);
// 最近更新时间
const latestUpdate = (
  posts[0] || { data: { date: new Date() } }
).data.date.toISOString();
// 构建时间
const buildDate = new Date();
---

<Layout>
  <Section>
    <div class="max-w-2xl mx-auto text-center mb-10 lg:mb-14">
      <h2 class="scroll-m-24 text-3xl font-semibold tracking-tight sm:text-3xl">
        最近文章
      </h2>
      <p
        class="mt-1 text-[1.05rem] text-muted-foreground sm:text-base sm:text-balance"
      >
        用文章的方式记录生活
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 lg:gap-y-10 gap-6">
      {
        posts.map((post) => (
          <Card className="relative mx-auto w-full max-w-sm pt-0 hover:bg-muted">
            <div class="absolute inset-0 z-30 aspect-video" />
            {/* ✅ 正确写法：必须使用 Image 组件 */}
            {post.data.cover ? (
              <Image
                src={post.data.cover}
                alt={post.data.title}
                width={800}
                height={800}
                class="relative z-20 aspect-video w-full object-cover"
              />
            ) : (
              <img
                src="https://avatar.vercel.sh/shadcn1"
                alt="Event cover"
                class="relative z-20 aspect-video w-full object-cover brightness-60 grayscale dark:brightness-40"
              />
            )}
            <CardHeader>
              <CardDescription>
                {post.data.date.toLocaleDateString()}
              </CardDescription>
              <CardTitle>
                <a href={new URL(post.customSlug || "", config.url)}>
                  <span class="absolute inset-0" />
                  {post.data.title}
                </a>
              </CardTitle>
              <CardDescription className="line-clamp-3">
                {getSummary(post.body ?? "")}
              </CardDescription>
            </CardHeader>
          </Card>
        ))
      }
    </div>

    <div class="mt-10 flex justify-center">
      <Button className="" variant="outline">
        <a href={new URL("post", config.url).href}> 更多文章 </a>
      </Button>
    </div>
  </Section>
  <section class="w-full overflow-hidden my-10 lg:my-14">
    <div class="max-w-7xl px-4 mx-auto">
      <CarouselDemo client:load />
    </div>
  </section>
  <Section>
    <StatisticCard
      client:load
      totalPosts={totalPosts}
      totalWords={totalWords}
      latestUpdate={latestUpdate}
      buildDate={buildDate}
    />
  </Section>
</Layout>
