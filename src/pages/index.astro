---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import "../styles/global.css";
import { CarouselDemo } from "@/components/index";
import {
  Card,
  CardAction,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";

// 1. 获取 blog 集合中的所有文章
const allPosts = await getCollection("blog");

// 2. 处理 URL 逻辑（保持和你之前的需求一致：扁平化 URL）
// 如果你的 [...slug].astro 逻辑是取最后一段，这里生成的链接也要对应
const posts = allPosts
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf())
  .slice(0, 6)
  .map((post) => {
    const slug = post.id.split("/").pop();
    return {
      ...post,
      customSlug: slug,
    };
  });
---

<Layout>
  <div class="mx-auto w-full max-w-7xl">
    <CarouselDemo client:load />
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 lg:gap-y-10 gap-6">
      {
        posts.map((post) => (
          <Card className="w-full max-w-sm">
            <CardHeader>
              <CardTitle>{post.data.title}</CardTitle>
              <CardDescription>
                发布于 {post.data.published.toLocaleDateString()}
              </CardDescription>
              <CardAction>
                <Badge variant="secondary">Featured</Badge>
              </CardAction>
            </CardHeader>
            <CardContent>1123</CardContent>
            <CardFooter className="flex-col gap-2"> hhhh </CardFooter>
          </Card>
        ))
      }
    </div>

    {
      posts.length === 0 && (
        <p>暂无文章，请检查 src/content/blog 目录下是否有 Markdown 文件。</p>
      )
    }
  </div>
</Layout>
