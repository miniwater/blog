---
import Layout from "../layouts/Layout.astro";
import { Dashboard } from "@/components/dashboard";
import { getCollection } from "astro:content";
import "../styles/global.css";
import { ModeToggle } from "@/components/ModeToggle";
// 1. 获取 blog 集合中的所有文章
const allPosts = await getCollection("blog");

// 2. 处理 URL 逻辑（保持和你之前的需求一致：扁平化 URL）
// 如果你的 [...slug].astro 逻辑是取最后一段，这里生成的链接也要对应
const posts = allPosts.map((post) => {
  const slug = post.id.split("/").pop();
  return {
    ...post,
    customSlug: slug,
  };
});
// console.log( import.meta.env.BASE_URL);
---

<Layout>
  <Dashboard client:load>
    <ModeToggle client:load />
    <ul>
      {
        posts.map((post) => (
          <li>
            {/* 生成的链接指向：http://localhost:4321/文章文件夹名 */}
            <a href={`/${post.customSlug}`}>{post.data.title}</a>
          </li>
        ))
      }
    </ul>
    {
      posts.length === 0 && (
        <p>暂无文章，请检查 src/content/blog 目录下是否有 Markdown 文件。</p>
      )
    }
  </Dashboard>

  <script is:inline>
    const getThemePreference = () => {
      if (
        typeof localStorage !== "undefined" &&
        localStorage.getItem("theme")
      ) {
        return localStorage.getItem("theme");
      }
      return window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
    };
    const isDark = getThemePreference() === "dark";
    document.documentElement.classList[isDark ? "add" : "remove"]("dark");

    if (typeof localStorage !== "undefined") {
      const observer = new MutationObserver(() => {
        const isDark = document.documentElement.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["class"],
      });
    }
  </script>
</Layout>
