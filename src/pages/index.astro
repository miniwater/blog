---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";
import "../styles/global.css";

// 1. 获取 blog 集合中的所有文章
const allPosts = await getCollection("blog");

// 2. 处理 URL 逻辑（保持和你之前的需求一致：扁平化 URL）
// 如果你的 [...slug].astro 逻辑是取最后一段，这里生成的链接也要对应
const posts = allPosts.map((post) => {
  const slug = post.id.split("/").pop();
  return {
    ...post,
    customSlug: slug,
  };
});
// console.log( import.meta.env.BASE_URL);
---

<Layout>
  {new URL("rss.xml", Astro.site)}
  <br />
  {Astro.url}
  <br />
  {new URL("rss.xml", Astro.url)}
  <ul>
    {
      posts.map((post) => (
        <li>
          {/* 生成的链接指向：http://localhost:4321/文章文件夹名 */}
          <a href={`/${post.customSlug}`}>{post.data.title}</a>
        </li>
      ))
    }
  </ul>
  {
    posts.length === 0 && (
      <p>暂无文章，请检查 src/content/blog 目录下是否有 Markdown 文件。</p>
    )
  }
</Layout>
