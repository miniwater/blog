---
import { Button } from "@/components/ui/button";
import {
  Card,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { games } from "@/content/games";
---

<Layout title="游戏库">
  <Section>
    <div
      class="relative grid grid-cols-[repeat(auto-fill,minmax(min(20rem,100%),1fr))] gap-8 mb-4"
    >
      {
        games.map((game) => (
          <Card className="relative mx-auto w-full max-w-sm pt-0 flex flex-col h-full transition-all hover:scale-[1.02] hover:shadow-xl group">
            <div class="absolute inset-0 z-30 aspect-video bg-black/35 transition-all group-hover:bg-black/0" />
            <img
              src={game.image.src}
              alt={game.name}
              class="relative z-20 aspect-video w-full object-cover"
            />
            <CardHeader className="flex-1">
              <CardTitle>{game.name}</CardTitle>
              <CardDescription>{game.description}</CardDescription>
            </CardHeader>
            <CardFooter>
              <Button
                className="w-full"
              >
                <a href={game.url} target="_blank" rel="noopener noreferrer">
                  查看详情
                </a>
              </Button>
            </CardFooter>
          </Card>
        ))
      }
    </div>
  </Section>
</Layout>
