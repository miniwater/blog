---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { Badge } from "@/components/ui/badge";
import { config } from "@/config";
import TOC from "@/components/TOC.astro";
import { Comment } from "@/components/comment";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    // 处理 slug：由于 loader 的 base 设置在 src/content/blog
    // 你的 id 可能是 "2026/php-利用imagemagick..."
    const finalSlug = post.id.split("/").pop();

    return {
      params: { slug: finalSlug },
      props: { post },
    };
  });
}

const { post } = Astro.props;

// 新版渲染方式：使用导出的 render(post)
const { Content, headings } = await render(post);

// 简单的字数统计逻辑
const content = post.body || "";
// 统计中文字符 + 英文单词
const wordCount = content.replace(/[^\w\s\u4e00-\u9fa5]/g, "").length;
// 假设阅读速度为每分钟 300 字
const readingTime = Math.ceil(wordCount / 300);
---

<Layout title={post.data.title}>
  <Section>
    <div
      class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-10 xl:max-w-5xl xl:grid-cols-[minmax(0,1fr)_var(--container-2xs)]"
    >
      <article class="w-full flex flex-col gap-4 lg:gap-6">
        <h1
          class="scroll-m-20 text-3xl font-extrabold tracking-tight text-balance"
        >
          {post.data.title}
        </h1>
        <div class="flex items-center gap-4 text-sm text-muted-foreground">
          <time datetime={post.data.date.toISOString()}>
            {
              post.data.date.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
          <span>•</span>
          <span>约 {wordCount} 字</span>
          <span>•</span>
          <span>预计阅读 {readingTime} 分钟</span>
        </div>

        <div class="flex w-full flex-wrap gap-2">
          {
            post.data.categories.map((category) => {
              const categorySlug = category.toLowerCase().replace(/\s+/g, "-");
              return (
                <Badge key={category}>
                  <a
                    class="no-underline text-inherit"
                    href={new URL(`category/${categorySlug}`, config.url)}
                  >
                    {category}
                  </a>
                </Badge>
              );
            })
          }
        </div>
        <div class="prose dark:prose-invert wrap-break-word">
          <Content />
        </div>
        <div class="flex w-full flex-wrap gap-2">
          {
            post.data.tags.map((tag) => {
              const tagSlug = tag.toLowerCase().replace(/\s+/g, "-");
              return (
                <Badge variant="secondary">
                  <a
                    class="no-underline"
                    href={new URL(`tag/${tagSlug}`, config.url)}
                  >
                    {tag}
                  </a>
                </Badge>
              );
            })
          }
        </div>
        <Comment client:load/>
      </article>
      <aside class="hidden xl:block">
        <div class="sticky top-28 self-start">
          <TOC headings={headings} />
        </div>
      </aside>
    </div>
  </Section>
</Layout>
