---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { Badge } from "@/components/ui/badge";
import { config } from "@/config";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => {
    // 处理 slug：由于 loader 的 base 设置在 src/content/blog
    // 你的 id 可能是 "2026/php-利用imagemagick..."
    const finalSlug = post.id.split("/").pop();

    return {
      params: { slug: finalSlug },
      props: { post },
    };
  });
}

const { post } = Astro.props;

// 新版渲染方式：使用导出的 render(post)
const { Content, headings } = await render(post);
---

<Layout title={post.data.title}>
  <Section>
    <div
      class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-10 xl:max-w-5xl xl:grid-cols-[minmax(0,1fr)_var(--container-2xs)]"
    >
      <article class="prose dark:prose-invert">
        <h1>{post.data.title}</h1>
        <div class="flex w-full flex-wrap gap-2">
          {
            post.data.categories.map((category) => {
              const categorySlug = category.toLowerCase().replace(/\s+/g, "-");
              return (
                <Badge key={category}>
                  <a
                    class="no-underline text-inherit"
                    href={new URL(`category/${categorySlug}`, config.url)}
                  >
                    {category}
                  </a>
                </Badge>
              );
            })
          }
        </div>
        <Content />
        <div class="flex w-full flex-wrap gap-2">
          {
            post.data.tags.map((tag) => {
              const tagSlug = tag.toLowerCase().replace(/\s+/g, "-");
              return (
                <Badge variant="secondary">
                  <a
                    class="no-underline"
                    href={new URL(`tag/${tagSlug}`, config.url)}
                  >
                    {tag}
                  </a>
                </Badge>
              );
            })
          }
        </div>
      </article>
      <aside class="hidden xl:block">
        <div class="sticky top-24 self-start">
          <nav class="flex flex-col gap-4 border-l pl-4">
            <p
              class="text-xs font-bold uppercase tracking-widest text-muted-foreground/70"
            >
              本页内容
            </p>
            <div class="flex flex-col gap-3">
              {
                headings.map((heading) => (
                  <a
                    href={`#${heading.slug}`}
                    class="text-[0.8rem] text-muted-foreground no-underline transition-colors hover:text-foreground data-[active=true]:font-medium data-[active=true]:text-foreground data-[depth=3]:pl-4 data-[depth=4]:pl-6"
                    data-active="false"
                    data-depth={heading.depth}
                  >
                    {heading.text}
                  </a>
                ))
              }
            </div>
          </nav>
        </div>
      </aside>
    </div>
  </Section>
</Layout>
