---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
// import Section from "@/components/Section.astro";
import { CollapsibleFileTree } from "@/components/docs-menu";
import { getDocTree } from "@/util/tree";
import TOC from "@/components/TOC.astro";

export async function getStaticPaths() {
  const allDocs = await getCollection("docs");

  return allDocs.map((entry) => {
    const path = entry.id; // 例如: "运维/Linux"
    const parts = path.split("/");

    // 1. 确保 fileName 至少是一个空字符串，避免 undefined
    const fileName = parts.length > 0 ? parts[parts.length - 1] : "";
    const folderName = parts.length >= 2 ? parts[parts.length - 2] : "";

    let finalSlug = path;

    // 2. 只有当 fileName 存在且有效时才进行逻辑判断
    if (fileName) {
      const isIndexFile = fileName.toLowerCase() === "index";
      const isSameAsFolder =
        folderName && fileName.toLowerCase() === folderName.toLowerCase();

      if (isIndexFile || isSameAsFolder) {
        // 缩短路径：将 "运维/运维" 或 "运维/index" 变为 "运维"
        finalSlug = parts.slice(0, -1).join("/");
      }
    }

    // 3. 处理根目录 index 的特殊情况 (params.slug 为 undefined 匹配根路径)
    const slugParam =
      finalSlug === "" || finalSlug === "index" ? undefined : finalSlug;

    return {
      params: { slug: slugParam },
      props: { entry },
    };
  });
}
const allDocs = await getCollection("docs");
const docTree = getDocTree(allDocs);
const { entry } = Astro.props;
// 使用 render 函数渲染内容
const { Content, headings } = await render(entry);

// 提取文件名作为标题
const displayTitle = entry.id.split("/").pop();
---

<Layout title={displayTitle} animate="fade">
  <!-- <Section class="py-0"> -->
  <div
    class="mx-auto w-full max-w-7xl flex-1 items-start md:grid md:grid-cols-[220px_minmax(0,1fr)_200px] lg:grid-cols-[240px_minmax(0,1fr)_260px] gap-6 px-4"
  >
    <!-- 左侧：全站文档目录 (固定在左侧) -->
    <aside
      class="fixed top-14 z-30 hidden h-[calc(100vh-3.5rem)] w-full shrink-0 md:sticky md:block overflow-y-auto py-6"
    >
      <CollapsibleFileTree client:load docTree={docTree} transition:persist />
    </aside>

    <!-- 中间：文章正文 -->
    <main class="relative py-6 lg:gap-10">
      <div class="mx-auto w-full min-w-0">
        <!-- 面包屑 (Breadcrumb) 建议放在这里 -->
        <div class="mb-4 text-sm text-muted-foreground">
          文档 / {entry.id.replace(/\//g, " / ")}
        </div>

        <div class="prose dark:prose-invert">
          <Content />
        </div>
      </div>
    </main>

    <!-- 右侧：当前文章 TOC (On This Page) -->
    <aside
      class="sticky top-14 hidden h-[calc(100vh-3.5rem)] shrink-0 md:block overflow-y-auto py-6"
    >
      <TOC headings={headings} />
    </aside>
  </div>
  <!-- </Section> -->
</Layout>
