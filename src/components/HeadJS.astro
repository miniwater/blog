<script is:inline>
  function applySiteSettings() {
    // 1. 定义所有的设置项及其逻辑
    const settings = [
      {
        key: "theme",
        default: () =>
          window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light",
        apply: (val) => {
          if (val === "system") {
            val = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          }
          document.documentElement.classList.toggle("dark", val === "dark");
        },
      },
      {
        key: "grayscale",
        default: "false",
        apply: (val) => {
          const enabled = val === "true";
          document.documentElement.style.filter = enabled
            ? "grayscale(100%)"
            : "none";
          document.documentElement.classList.toggle("grayscale-mode", enabled);
        },
      },
      {
        key: "rtl",
        default: "false",
        apply: (val) => {
          document.documentElement.dir = val === "true" ? "rtl" : "ltr";
        },
      },
      {
        key: "hue",
        default: null,
        apply: (val) => {
          if (val !== null) {
            const oklchValue = `oklch(0.6 0.15 ${val})`;
            document.documentElement.style.setProperty("--primary", oklchValue);
          }
        },
      },
    ];

    // 2. 统一初始化函数

    settings.forEach((setting) => {
      const stored = localStorage.getItem(setting.key);
      const value =
        stored !== null
          ? stored
          : typeof setting.default === "function"
            ? setting.default()
            : setting.default;
      setting.apply(value);
    });

    // 3. 统一监听跨标签页同步
    // window.addEventListener("storage", (e) => {
    //   const setting = settings.find((s) => s.key === e.key);
    //   if (setting) {
    //     setting.apply(e.newValue);
    //   }
    // });

    // 4. 主题观察器（保留原有的 MutationObserver 逻辑，但进行简化）
    // const observer = new MutationObserver(() => {
    //   const isDark = document.documentElement.classList.contains("dark");
    //   localStorage.setItem("theme", isDark ? "dark" : "light");
    // });
    // observer.observe(document.documentElement, {
    //   attributes: true,
    //   attributeFilter: ["class"],
    // });
  }
  // 2. 首次运行（防止首屏闪烁）
  applySiteSettings();

  // 3. 核心：监听 Astro 视图转换事件
  // astro:after-swap 确保在 DOM 替换后立即重新应用设置
  document.addEventListener("astro:after-swap", applySiteSettings);

  // 4. 监听跨标签页同步（只需在首次加载时绑定一次）
  window.addEventListener("storage", (e) => {
    // 这里建议重新运行 applySiteSettings 或者保留你原有的 find 逻辑
    applySiteSettings();
  });

  async function initPagefind() {
    try {
      const pagefind = await import("/pagefind/pagefind.js");
      await pagefind.init();
      window.pagefind = pagefind; // 挂载到全局
    } catch (e) {
      console.log("Pagefind not found, which is normal in dev mode.");
    }
  }
  initPagefind();
</script>
