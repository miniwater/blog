---
import Page from "@/components/Page.astro";
import { Card } from "@/components/ui/card";
import type { CollectionEntry } from "astro:content";
import type { Page as AstroPage } from "astro"; // 导入 Astro 分页对象的内置类型
import { Image } from "astro:assets";
import { config } from "@/config";

interface Props {
  posts:(CollectionEntry<"blog"> & { customSlug: string })[]; // 明确是 blog 集合的条目数组
  page: AstroPage<CollectionEntry<"blog">>; // 明确分页对象的类型
}

const { posts, page } = Astro.props;

// 文章摘要
function getSummary(body: string, length = 200) {
  const cleanBody = body
    // 1. 过滤图片: ![描述](链接)
    .replace(/!\[.*?\]\(.*?\)/g, "")
    // 2. 过滤常规链接，只保留文本内容: [文本](链接) -> 文本
    .replace(/\[(.*?)\]\(.*?\)/g, "$1")
    // 3. 过滤标题、粗体、斜体、删除线、行内代码
    .replace(/[#*`~]/g, "")
    // 4. 过滤多余的换行符和空格，让摘要更紧凑
    .replace(/\s+/g, " ")
    .trim();
  return cleanBody.slice(0, length) + (cleanBody.length > length ? "..." : "");
}
---

<div class="space-y-8">
  {
    posts.map((post) => (
      <Card className="relative flex flex-col md:flex-row overflow-hidden p-0 gap-0">
        {post.data.cover && (
          <div class="w-full md:w-48 shrink-0">
            <Image
              src={post.data.cover}
              alt={post.data.title}
              width={800}
              height={800}
              class="h-full w-full object-cover aspect-video md:aspect-auto"
            />
          </div>
        )}
        <div class="flex flex-col justify-between p-3">
          <div class="space-y-2">
            <div
              class="flex items-center gap-x-4 text-xs whitespace-nowrap overflow-x-scroll"
              style="scrollbar-width: none;"
            >
              <time
                datetime={post.data.date.toLocaleDateString()}
                class="text-gray-500"
              >
                {post.data.date.toLocaleDateString()}
              </time>
              {post.data.categories?.map((category) => (
                <a
                  href={
                    new URL(
                      `/category/${category.toLowerCase().replace(/\s+/g, "-")}`,
                      config.url,
                    ).href
                  }
                  class="relative z-10 rounded-full bg-gray-50 dark:bg-gray-800 px-3 py-1.5 font-medium text-secondary-foreground hover:bg-gray-100 dark:hover:bg-gray-700"
                >
                  {category}
                </a>
              ))}
            </div>
            <h3 class="mt-3 text-lg font-semibold leading-6">
              <a href={new URL(post.customSlug || "", config.url)}>
                  <span class="absolute inset-0" />
                  {post.data.title}
                </a>
            </h3>
            <p class="text-muted-foreground"> {getSummary(post.body ?? "")}</p>
            <div class="flex flex-wrap items-center gap-x-1 mt-4 text-xs text-gray-600 dark:text-gray-400 whitespace-nowrap">
              {post.data.tags?.map((tag) => (
                <a
                  href={
                    new URL(
                      `/tag/${tag.toLowerCase().replace(/\s+/g, "-")}`,
                      config.url,
                    ).href
                  }
                  class="inline-block mr-2 hover:bg-gray-200 dark:hover:bg-gray-700 p-1.5 rounded-full z-10"
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>
        </div>
      </Card>
    ))
  }
  {posts.length === 0 && <p>暂无文章。</p>}
  <Page page={page} />
</div>


